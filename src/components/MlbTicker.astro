---
// Componente de Ticker de MLB en Vivo (Datos Inyectados por Cliente)
---

<div class="w-full bg-red-600 text-white flex items-center h-10 overflow-hidden relative border-b-2 border-red-800">
    <div class="absolute left-0 top-0 bottom-0 bg-red-700 font-bold uppercase tracking-widest px-4 sm:px-6 flex items-center justify-center z-20 shadow-lg text-[10px] sm:text-xs text-center whitespace-nowrap">
        <span class="animate-pulse w-2 h-2 rounded-full bg-white mr-2 inline-block"></span> EN VIVO
    </div>
    
    <!-- Animación CSS Marquee y Contenedor -->
    <div class="ticker-wrap flex items-center ml-[100px] sm:ml-[120px] w-full h-full relative overflow-hidden mask-fade">
        <div id="mlb-ticker-content" class="ticker-move flex items-center whitespace-nowrap w-max gap-8 font-oswald text-sm md:text-base font-bold tracking-wide">
            {/* Estado Inicial de Carga */}
            <span class="text-white/70 animate-pulse tracking-widest">CARGANDO RESULTADOS DE LA MLB...</span>
            <span class="text-white/70 animate-pulse tracking-widest">OBTENIENDO DATOS EN VIVO...</span>
        </div>
    </div>
</div>

<script>
    async function fetchMlbScores() {
        try {
            // API Pública de MLB Schedule con 'hydrate=linescore' para saber el Inning
            const response = await fetch('https://statsapi.mlb.com/api/v1/schedule?sportId=1&hydrate=linescore');
            const data = await response.json();
            
            const tickerContainer = document.getElementById('mlb-ticker-content');
            if(!tickerContainer) return;

            let htmlBlocks = [];
            
            if (data.dates && data.dates.length > 0) {
                const games = data.dates[0].games;
                
                games.forEach(game => {
                    const awayTeam = game.teams.away.team.name.split(' ').pop(); // ej: Yankees
                    const homeTeam = game.teams.home.team.name.split(' ').pop(); // ej: Red Sox
                    const awayScore = game.teams.away.score || 0;
                    const homeScore = game.teams.home.score || 0;
                    
                    const state = game.status.detailedState; // "Final", "In Progress", "Scheduled"
                    
                    let statusHtml = '';
                    let opacityClass = 'opacity-100'; // Full brillante para live
                    
                    if (state === 'Scheduled' || state === 'Pre-Game') {
                        const gameTime = new Date(game.gameDate).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                        statusHtml = `<span class="text-[10px] bg-blue-900 px-2 py-0.5 rounded text-white ml-2">${gameTime}</span>`;
                        opacityClass = 'opacity-70';
                    } else if (state === 'Final' || state === 'Game Over') {
                        statusHtml = `<span class="text-[10px] bg-gray-900 px-2 py-0.5 rounded text-gray-300 ml-2">FINAL</span>`;
                        opacityClass = 'opacity-60';
                    } else if (state === 'In Progress') {
                        const inning = game.linescore?.currentInningOrdinal || '';
                        const isTop = game.linescore?.isTopHalf ? 'Alta' : 'Baja';
                        statusHtml = `<span class="text-[10px] bg-red-800 px-2 py-0.5 rounded text-white ml-2 animate-pulse">${isTop} ${inning}</span>`;
                    } else {
                        statusHtml = `<span class="text-[10px] bg-gray-800 px-2 py-0.5 rounded text-white ml-2">${state}</span>`;
                    }

                    const block = `
                        <div class="flex items-center gap-3 ${opacityClass}">
                            <span class="text-gray-300 uppercase">${awayTeam}</span> 
                            <span class="text-white text-lg font-extrabold">${awayScore}</span>
                            <span class="text-gray-300 mx-1">-</span>
                            <span class="text-white text-lg font-extrabold">${homeScore}</span>
                            <span class="text-gray-300 uppercase">${homeTeam}</span>
                            ${statusHtml}
                        </div>
                    `;
                    
                    htmlBlocks.push(block);
                });
            }

            if (htmlBlocks.length === 0) {
                tickerContainer.innerHTML = '<span class="text-white/70">NO HAY PARTIDOS PROGRAMADOS PARA HOY</span>';
                return;
            }

            // Unimos con un separador rojo y multiplicamos los bloques para que la marquesina css NUNCA se corte
            const blockString = htmlBlocks.join('<span class="text-red-900 mx-2">|</span>');
            tickerContainer.innerHTML = blockString + '<span class="text-red-900 mx-2">|</span>' + blockString + '<span class="text-red-900 mx-2">|</span>' + blockString;

        } catch (err) {
            console.error('Error fetching live MLB scores:', err);
            const tickerContainer = document.getElementById('mlb-ticker-content');
            if(tickerContainer) tickerContainer.innerHTML = '<span class="text-red-300">ERROR AL CARGAR RESULTADOS EN VIVO</span>';
        }
    }

    // Ejecutar FETCH sólo en el cliente
    fetchMlbScores();
    // Refrescar datos cada 1 minuto (60000ms)
    setInterval(fetchMlbScores, 60000);
</script>

<style is:inline>
    .mask-fade {
        -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }

    .ticker-move {
        display: flex;
        animation: ticker 120s linear infinite;
        padding-left: 100%;
    }

    .ticker-move:hover {
        animation-play-state: paused;
        cursor: grab;
    }

    @keyframes ticker {
        0% { transform: translateX(0); }
        100% { transform: translateX(-150%); }
    }
</style>

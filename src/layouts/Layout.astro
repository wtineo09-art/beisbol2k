---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
import Header from '../components/Header.astro';
import MlbTicker from '../components/MlbTicker.astro';
import TeamSlider from '../components/TeamSlider.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="La web #1 de béisbol y MLB." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700;800&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">

		<!-- Google AdSense Script -->
		{import.meta.env.PROD && (
			<script 
				async 
				src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${import.meta.env.ADSENSE_CLIENT_ID || "ca-pub-0000000000000000"}`} 
				crossorigin="anonymous"
			></script>
		)}
	</head>
	<body class="bg-gray-100 font-sans antialiased text-gray-900 m-0 p-0">
		
		<!-- Ticker Resultados en Vivo -->
		<MlbTicker />

		<!-- Header / Navegación Global -->
		<Header />

		<!-- Sub Navegación: Slider de Equipos en Formato Pills -->
		<TeamSlider />

		<!-- Contenido Dinámico -->
		<main class="min-h-screen">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="bg-gray-900 text-gray-400 py-16 mt-20 border-t-8 border-red-600">
			<div class="max-w-7xl mx-auto px-4">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
					
					<!-- Columna 1: Marca -->
					<div>
						<h3 class="text-white text-3xl font-extrabold uppercase font-oswald tracking-tighter mb-4">Béisbol<span class="text-red-500">2K</span></h3>
						<p class="text-sm font-open leading-relaxed mb-6">El hogar de los verdaderos fanáticos de las Grandes Ligas. Noticias, resultados en vivo y reportajes a fondo sobre tus equipos favoritos.</p>
						<p class="text-xs">Red impulsada por HostingCano.</p>
					</div>

					<!-- Columna 2: Enlaces -->
					<div>
						<h4 class="text-white text-lg font-bold uppercase font-oswald tracking-widest mb-6 border-b border-gray-800 pb-2">Secciones</h4>
						<ul class="space-y-3 text-sm font-bold uppercase tracking-wide flex flex-col">
							<li><a href="/" class="hover:text-red-500 transition-colors">Inicio</a></li>
							<li><a href="/mlb-en-vivo" class="hover:text-red-500 transition-colors">Ver Pasión en Vivo</a></li>
							<li><a href="/politica-de-privacidad" class="hover:text-red-500 transition-colors">Política de Privacidad</a></li>
						</ul>
					</div>

					<!-- Columna 3: Newsletter -->
					<div>
						<h4 class="text-white text-lg font-bold uppercase font-oswald tracking-widest mb-6 border-b border-gray-800 pb-2">Boletín Béisbol2K</h4>
						<p class="text-sm font-open mb-4">Recibe las noticias más calientes de la MLB directo en tu bandeja de entrada.</p>
						<form action="https://formsubmit.co/wtineo09@gmail.com" method="POST" class="flex flex-col gap-3">
							<!-- Desactivar captcha temporal de FormSubmit para mejor UX -->
							<input type="hidden" name="_captcha" value="false">
							<!-- Redirigir a la misma página (o puedes crear una página /gracias) -->
							<input type="hidden" name="_next" value="https://beisbol2k.com/">
							<input type="hidden" name="_subject" value="¡Nueva Suscripción al Boletín Béisbol2K!">
							
							<input type="email" name="email" placeholder="Tu correo electrónico" class="bg-gray-800 text-white px-4 py-3 border border-gray-700 focus:outline-none focus:border-red-500" required />
							<button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold uppercase tracking-widest py-3 transition-colors shadow-lg">Suscribirme</button>
						</form>
					</div>
					
				</div>
				
				<div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center text-xs">
					<p>&copy; {new Date().getFullYear()} Béisbol2K. Todos los derechos reservados.</p>
					<div class="flex space-x-4 mt-4 md:mt-0">
						<a href="#" class="hover:text-white transition-colors uppercase font-bold tracking-widest">Facebook</a>
						<a href="#" class="hover:text-white transition-colors uppercase font-bold tracking-widest">X (Twitter)</a>
						<a href="#" class="hover:text-white transition-colors uppercase font-bold tracking-widest">Instagram</a>
					</div>
				</div>
			</div>
		</footer>
		
	</body>
</html>
<style is:global>
	html {
		font-family: 'Open Sans', system-ui, sans-serif;
	}
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Oswald', sans-serif;
	}
</style>

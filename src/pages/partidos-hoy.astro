---
import Layout from '../layouts/Layout.astro';
import AdsenseUnit from '../components/AdsenseUnit.astro';
import { mlbTeams } from '../data/mlbTeams.js';

// Título y meta para el SEO
const title = "Partidos de MLB Hoy | Calendario y Horarios en Vivo - Béisbol2K";
const description = "Consulta todos los juegos de las Grandes Ligas (MLB) programados para hoy. Horarios actualizados y enlaces para ver la transmisión en vivo.";

/**
 * Función para mapear el nombre del equipo de la API al slug de nuestro sitio.
 * Intentamos encontrar coincidencias en el array mlbTeams.
 */
function getTeamSlug(apiTeamName) {
    // Casos especiales de nombres
    const lowerName = apiTeamName.toLowerCase();
    const team = mlbTeams.find(t => 
        lowerName.includes(t.slug.split('-')[0]) || 
        t.name.toLowerCase().includes(lowerName) ||
        lowerName.includes(t.name.toLowerCase().split(' ').pop())
    );
    return team ? team.slug : 'mlb-en-vivo';
}

// Fetch de los partidos del día (SportID 1 es MLB)
let games = [];
let error = null;

try {
    const response = await fetch('https://statsapi.mlb.com/api/v1/schedule?sportId=1&hydrate=linescore,team');
    const data = await response.json();
    if (data.dates && data.dates.length > 0) {
        games = data.dates[0].games;
    }
} catch (e) {
    console.error("Error al obtener calendario de MLB:", e);
    error = "No se pudo cargar el calendario en este momento.";
}

// Formateador de fecha
const today = new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

---

<Layout title={title}>
    <Fragment slot="head">
        <meta name="description" content={description} />
    </Fragment>

    <div class="bg-blue-900 text-white py-12 border-b-[6px] border-red-600 shadow-inner relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[url('https://images.unsplash.com/photo-1508344928928-7165b67de128?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center"></div>
        <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
            <h1 class="text-4xl md:text-6xl font-extrabold uppercase font-oswald tracking-tighter leading-tight mb-2">
                Partidos de <span class="text-red-500">Hoy</span>
            </h1>
            <p class="text-lg opacity-80 uppercase tracking-widest font-bold font-oswald">{today}</p>
        </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 py-12">
        
        <!-- ADSENSE TOP -->
        <AdsenseUnit format="auto" className="mb-12 flex justify-center w-full" />

        {error ? (
            <div class="bg-red-50 border-l-4 border-red-500 p-8 text-center rounded-r-md shadow-sm">
                <p class="text-red-700 font-bold text-xl">{error}</p>
                <p class="text-gray-600 mt-2">Por favor, intenta recargar la página más tarde.</p>
            </div>
        ) : games.length === 0 ? (
            <div class="bg-gray-50 border-l-4 border-blue-900 p-8 text-center rounded-r-md shadow-sm">
                <p class="text-blue-900 font-bold text-xl uppercase font-oswald">No hay partidos programados para el día de hoy.</p>
                <p class="text-gray-600 mt-2">Vuelve mañana para ver el nuevo calendario de la MLB.</p>
            </div>
        ) : (
            <div class="flex flex-col gap-6">
                {games.map((game, index) => {
                    const awayTeam = game.teams.away.team.name;
                    const homeTeam = game.teams.home.team.name;
                    const gameTime = new Date(game.gameDate).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit', hour12: true });
                    const status = game.status.detailedState;
                    
                    const awaySlug = getTeamSlug(awayTeam);
                    const homeSlug = getTeamSlug(homeTeam);

                    return (
                        <>
                            <div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-shadow duration-300 overflow-hidden border border-gray-100 flex flex-col md:flex-row items-center p-6 md:p-8 relative group">
                                
                                {/* Info del Partido (Móvil: Arriba, Desktop: Izquierda) */}
                                <div class="flex-1 flex flex-col md:flex-row items-center justify-between w-full gap-6">
                                    
                                    {/* Equipo Visitante */}
                                    <div class="flex-1 text-center md:text-right">
                                        <h2 class="text-xl md:text-2xl font-extrabold font-oswald text-gray-900 uppercase tracking-tight group-hover:text-blue-900 transition-colors">
                                            {awayTeam}
                                        </h2>
                                    </div>

                                    {/* VS y Hora */}
                                    <div class="flex flex-col items-center justify-center min-w-[120px] py-4 md:py-0 border-y md:border-y-0 md:border-x border-gray-100 px-6">
                                        <span class="text-red-600 font-black text-2xl font-oswald mb-1">VS.</span>
                                        <span class="text-gray-500 font-bold text-sm tracking-widest uppercase">{gameTime}</span>
                                        <span class="text-[10px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full mt-2 font-bold uppercase">{status === 'In Progress' ? 'EN JUEGO' : status}</span>
                                    </div>

                                    {/* Equipo Local */}
                                    <div class="flex-1 text-center md:text-left">
                                        <h2 class="text-xl md:text-2xl font-extrabold font-oswald text-gray-900 uppercase tracking-tight group-hover:text-blue-900 transition-colors">
                                            {homeTeam}
                                        </h2>
                                    </div>

                                </div>

                                {/* Botón de Acción */}
                                <div class="mt-8 md:mt-0 md:ml-10 w-full md:w-auto">
                                    <a 
                                        href={`/mlb-en-vivo/${homeSlug}`} 
                                        class="block w-full text-center bg-blue-900 hover:bg-red-600 text-white font-bold uppercase tracking-widest text-xs px-8 py-4 rounded-lg transition-all shadow-lg hover:-translate-y-1 active:scale-95"
                                    >
                                        Ver Transmisión
                                    </a>
                                </div>

                                {index % 5 === 4 && (
                                    <div class="w-full mt-4">
                                        <AdsenseUnit format="auto" />
                                    </div>
                                )}
                            </div>
                        </>
                    );
                })}
            </div>
        )}

        <!-- ADSENSE BOTTOM -->
        <AdsenseUnit format="auto" className="mt-12 flex justify-center w-full" />

        {/* CONTENIDO SEO ADICIONAL */}
        <div class="mt-20 bg-white p-8 md:p-12 shadow-lg border-t-8 border-gray-900 rounded-b-md">
            <h2 class="text-3xl font-extrabold uppercase font-oswald text-gray-900 mb-6">Calendario MLB Hoy: No te pierdas ni un pitcheo</h2>
            <div class="prose prose-lg max-w-none text-gray-700 font-open">
                <p>
                    Bienvenido al centro de transmisiones de Béisbol2K. Aquí podrás encontrar todos los <strong>partidos de MLB para hoy</strong> actualizados en tiempo real. Sabemos que la pasión por las Grandes Ligas no descansa, y por eso te traemos una cartelera completa con los horarios exactos de cada encuentro.
                </p>
                <p>
                    Ya sea que sigas a los históricos Yankees de Nueva York, los dominantes Dodgers de Los Ángeles o cualquier otro de los 30 equipos de la gran carpa, esta página es tu punto de partida. Solo selecciona el partido que deseas ver y serás redirigido a nuestra sección de **transmisión en vivo oficial**.
                </p>
                <p>
                    Recuerda que los horarios se ajustan automáticamente y la información proviene directamente de los servidores de la MLB para garantizar la mayor precisión posible durante toda la temporada regular y postemporada.
                </p>
            </div>
        </div>

    </div>
</Layout>

<style>
    /* Efecto de hover sutil para las tarjetas */
    .group:hover {
        border-color: rgba(30, 58, 138, 0.2);
    }
</style>

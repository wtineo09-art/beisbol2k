# WordPress GraphQL API URL
# Ejemplo: https://html.beisbol2k.com/graphql
WP_GRAPHQL_URL=https://html.beisbol2k.com/graphql

# Google AdSense Configuration
# Tu ID de cliente de AdSense (ca-pub-XXXXXXXXXXXXXXXX)
ADSENSE_CLIENT_ID=ca-pub-0000000000000000

# El ID del bloque de anuncios predeterminado
ADSENSE_DEFAULT_SLOT=3602370027

# Nota: Estas variables deben configurarse en el panel de Vercel
# para los entornos de Preview y Producción.
